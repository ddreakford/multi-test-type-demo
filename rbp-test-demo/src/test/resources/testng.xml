<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RBP Demo Suite" parallel="classes" thread-count="2">
    <test name="Auth Service Tests">
        <classes>
            <class name="com.demo.tests.api.AuthApiTest"/>
        </classes>
    </test>
    <test name="Booking Service Tests">
        <classes>
            <class name="com.demo.tests.api.BookingApiTest"/>
        </classes>
    </test>
    <test name="Booking UI Tests">
        <classes>
            <class name="com.demo.tests.ui.BookingUITest"/>
        </classes>
    </test>

    <!-- Regression suite: validates behaviors from the Manual Test Tutorial -->
    <test name="Regression - Homepage UI (TC-UI-001)">
        <classes>
            <class name="com.demo.tests.regression.HomepageUITest"/>
        </classes>
    </test>
    <test name="Regression - Booking Flow (TC-BOOK-001)">
        <classes>
            <class name="com.demo.tests.regression.BookingFlowUITest"/>
        </classes>
    </test>
    <test name="Regression - Contact Form (TC-MSG-001)">
        <classes>
            <class name="com.demo.tests.regression.ContactFormUITest"/>
        </classes>
    </test>
</suite>
